# Dakota input file: hydroRaVENS Cannon River parameter calibration
# Generated by generate_dakota_in.py from params.yml — do not edit by hand.
#
# Active parameters (13):
#   log__t_efold_soil: log10 soil-zone e-folding time [days]
#   log__t_efold_karst: log10 karst e-folding time [days]
#   log__t_efold_deep: log10 deep groundwater e-folding time [days]
#   f_exfiltration_soil: fraction of soil-zone exfiltration to stream (remainder recharges karst)
#   f_exfiltration_karst: fraction of karst exfiltration to stream (remainder recharges deep)
#   PDD_melt_factor: degree-day snowmelt rate [mm SWE / degC / day]
#   log__fdd_threshold: log10 frozen-ground-index threshold [degC·day]
#   snow_insulation_k: snow insulation decay constant [mm⁻¹ SWE]
#   recession_b_soil: power-law recession exponent for soil zone [dimensionless]; b=1 is linear
#   recession_b_karst: power-law recession exponent for karst [dimensionless]; b=1 is linear
#   et_scale: global ET multiplier [dimensionless]; diagnoses Thornthwaite magnitude bias
#   f_tile_soil: tile-drain fraction from soil reservoir
#   log__tau_tile: log10 tile-drain e-folding time [days]
# Fixed (inactive) parameters:
#   et_alpha = 1.0  (ET partition fraction — fixed at 1.0 (all ET from soil reservoir))
#   log__H0_pdm_soil = 2.3  (PDM characteristic storage depth — inactive in Y01 (PDM removed))
#   f_direct_runoff = 0.0  (fast-bypass fraction of daily recharge)
#   baseflow_Q = 0.0  (constant regional groundwater import [mm/day])
#   log__routing_K = 0.0  (log10 Nash-cascade storage time constant [days])

environment
  top_method_pointer = 'HYBRID'
  tabular_data
    tabular_data_file = 'dakota.dat'

method
  id_method = 'HYBRID'
  hybrid sequential
    method_pointer_list = 'EGO' 'PS'

method
  id_method = 'EGO'
  efficient_global
    gaussian_process surfpack
    initial_samples = 300
    seed = 12345
    output quiet
  model_pointer = 'M1'

method
  id_method = 'PS'
  coliny_pattern_search
    max_function_evaluations = 200
    convergence_tolerance = 0.0001
    output quiet
  model_pointer = 'M1'

model
  id_model = 'M1'
  single
    interface_pointer = 'I1'
  variables_pointer = 'V1'
  responses_pointer = 'R1'

variables
  id_variables = 'V1'
  continuous_design = 13
    descriptors   = 'log__t_efold_soil' 'log__t_efold_karst' 'log__t_efold_deep' 'f_exfiltration_soil' 'f_exfiltration_karst' 'PDD_melt_factor' 'log__fdd_threshold' 'snow_insulation_k' 'recession_b_soil' 'recession_b_karst' 'et_scale' 'f_tile_soil' 'log__tau_tile'
    lower_bounds  =  1.0  2.5  3.5  0.01  0.01  0.1  0.0  0.0  1.5  1.5  0.5  0.0  0.0
    upper_bounds  =  2.7  4.5  5.0  0.99  0.99  10.0  3.0  0.15  6.0  6.0  2.0  0.99  1.146
    initial_point =  1.8  3.5  4.0  0.1  0.7  1.0  1.9  0.057  2.2  2.2  1.0  0.3  0.845

interface
  id_interface = 'I1'
  analysis_driver = 'bash run_driver.sh'
  fork
    parameters_file = 'params.in'
    results_file    = 'results.out'
    work_directory
      named 'out/run'
      directory_tag
      directory_save
    file_save
    copy_files 'driver.py' 'cannon_cfg_1991_2011_soil_karst_deep.yml' 'Cannon1991-2011Input.csv' 'run_driver.sh' 'params.yml'
    asynchronous
      evaluation_concurrency = 4

responses
  id_responses = 'R1'
  objective_functions = 1
    response_descriptors = 'neg_kge'
  no_gradients
  no_hessians
